@@ -0,0 +1,25 @@
+
+#include "syscall.h"
+
+int main() {
+    SpaceId pid1, pid2, pid3;
+    int myPid = GetPid();
+    PrintString("Created and running Parent process\n");
+    //parent (pid=0)
+    if (myPid == 0) {
+        PrintString("Creating 3 child processes\n");
+        PrintString("          Process 1: Priority 30 (Medium)\n");
+        PrintString("  Process 2: Priority 50 (High)\n");
+        PrintString("  Process 3: Priority 10 (Low) \n");
+        // Create child 
+        pid1 = ExecWithPriority("../test/worker1", 30); // added new syscall for execwithpriority
+        pid2 = ExecWithPriority("../test/worker2", 50);   
+        pid3 = ExecWithPriority("../test/worker3", 10);   
+        Join(pid1);
+        Join(pid2);
+        Join(pid3);
+	PrintString("Parent process finish\n");
+      }
+    return 0;
+   
+}
